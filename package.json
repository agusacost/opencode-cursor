{
  "name": "@agustinacost/opencode-cursor",
  "version": "0.1.2",
  "description": "OpenCode plugin that connects Cursor models via API key and a local OpenAI-compatible proxy.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "opencode",
    "cursor",
    "plugin",
    "ai",
    "proxy",
    "apikey",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agusacost/opencode-cursor.git"
  },
  "bugs": {
    "url": "https://github.com/agusacost/opencode-cursor/issues"
  },
  "homepage": "https://github.com/agusacost/opencode-cursor#readme",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-runtime.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "powershell -NoProfile -Command \"$bun = Join-Path $env:USERPROFILE '.bun\\\\bin\\\\bun.exe'; & $bun ./test/smoke.ts\""
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.10.2",
    "@opencode-ai/plugin": "^1.14.39",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "typescript": "^5.9.3"
  }
}
